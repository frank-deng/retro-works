log_file="telnetd.log"
log_level="INFO"
pid_file=""telnetd.pid"
detach=true
watchdog_timeout=10
modules=[
"telnet.termux:TelnetServerTermux",
"telnet.pam:TelnetServerPAM",
"telnet.ssh:TelnetServerSSH"
]

[TelnetServerTermux]
host="127.0.0.1"
port=8023
max_connection=10
buf_size=4096
username="username"
password="sha256_hash"
shell="/bin/bash"
term="ansi"

[TelnetServerPAM]
host="127.0.0.1"
port=8024
max_connection=10
buf_size=4096
term="ansi"

[TelnetServerSSH]
host="127.0.0.1"
port=8025
max_connection=10
buf_size=4096
ssh_host="127.0.0.1"
ssh_port=8023
term="ansi"

