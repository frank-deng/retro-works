log_file="telnetd.log"
log_level="INFO"
pid_file=""telnetd.pid"
detach=true
watchdog_timeout=10
modules=[
"telnet.termux:TelnetServerTermux",
"telnet.ssh:TelnetServerSSH"
]

[TelnetServerTermux]
host="127.0.0.1"
port=8023
max_connection=10
buf_size=4096
username="username"
password="sha256_hash"
shell="/bin/bash"
term="ansi"
rows=24
columns=80

[[TelnetServerSSH.servers]]
host="127.0.0.1"
port=8025
max_connection=10
buf_size=4096
ssh_host="host1"
ssh_port=22
term="ansi"
rows=24
columns=80

[[TelnetServerSSH.servers]]
host="127.0.0.1"
port=8026
max_connection=10
buf_size=4096
ssh_host="host2"
ssh_port=8022
term="ansi"
rows=24
columns=80

