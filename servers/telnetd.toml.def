log_file="telnetd.log"
log_level="DEBUG"
pid_file="/data/data/com.termux/files/home/telnetd.pid"
detach=true
watchdog_timeout=10
modules=[
	"telnetserver:TelnetServer"
]

[TelnetServer]
host="127.0.0.1"
port=8023
max_connection=10

[[TelnetServer.users]]
match="xxx"
module="telnetserver.termux.TermuxHandler"
password="xxx"

[[TelnetServer.users]]
match="xxx"
module="telnetserver.termux.SSHHandler"
username="xxx"

[[TelnetServer.users]]
match=".*"
module="telnetserver.termux.PAMHandler"

