log_file="server.log"
log_level="INFO"
pid_file="server.pid"
detach=true
watchdog_timeout=10
modules=[
"web:WebServer",
"ftp.sftp:FTP2SFTPBridgeServer",
"ftp.ternux:FTPTermuxServer"
]

[web]
host="127.0.0.1"
port=8080
encoding="gbk"
links=[
{label="邮件中心",href="/mail.asp"},
{label="天气预报",href="/weather.asp"}
]
news_page_size=30
image_max_size=[360,960]
inline_image=true
news_api="xxx"
weather_api="xxx"
weather_key="xxx"

[mail]
pagesize=10
host="mysite.com"

[mail.db]
db_file='mail.db'
maxsize=10
minsize=2
idle_timeout=30

[[mail.users]]
uid=100
username="username"
password="sha256_hash"

[[mail.users]]
uid=1
username="deepseek"
module="askbot:MailUserRobotDeepseek"
deepseek_key="xxx"

[[mail.users]]
uid=2
username="erine"
module="askbot:MailUserRobotErine"
client_id="xxx"
client_secret="xxx"

[[FTP2SFTPBridgeServer.servers]]
host="127.0.0.1"
port=8021
pasv_addr="10.0.2.2"
pasv_port_start=10000
pasv_port_end=10010
sftp_host="127.0.0.1"
sftp_port=8022
max_connections=10
encoding="gbk"

[FTPTermuxServer]
host="127.0.0.1"
port=8021
pasv_addr="10.0.2.2"
pasv_port_start=10000
pasv_port_end=10010
max_connections=10
encoding="gbk"
username="username"
password="sha256_hash"

