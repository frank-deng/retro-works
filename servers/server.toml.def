log_file="server.log"
log_level="INFO"
pid_file="server.pid"
detach=true
watchdog_timeout=10
modules=[
"web:WebServer"
]

[web]
host="127.0.0.1"
port=8080
encoding="gbk"
template_dir="web"
links=[
	{label="天气预报",link="weather.asp"}
]
news_page_size=30
image_max_size=[360,960]
inline_image=true
news_api="xxx"
weather_api="xxx"
weather_key="xxx"

[[web.routes]]
path="/static"
static="web/static"

[[web.routes]]
path=["/","/index.asp"]
module="web.index:index"

[[web.routes]]
path="/select_city.asp"
module="web.weather:select_city"

[[web.routes]]
path="/weather.asp"
module="web.weather:weather"

[[web.routes]]
path="/news.asp"
module="web.news:news_handler"

[[web.routes]]
path="/news_images/{image_key}.jpg"
module="web.news:news_image_handler"

[[web.routes]]
path="/blog/{path:.*}"
module="web:StaticWithIndex"
rootdir="../blog-maker/dist"
index=["index.html","index.htm"]

