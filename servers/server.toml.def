log_file="server.log"
log_level="INFO"
pid_file="server.pid"
detach=true
watchdog_timeout=10
modules=[
"web:WebServer"
]

[web]
host="127.0.0.1"
port=8080
encoding="gbk"
links=[
{label="邮件中心",href="/mail.asp"},
{label="天气预报",href="/weather.asp"}
]
news_page_size=30
image_max_size=[360,960]
inline_image=true
news_api="xxx"
weather_api="xxx"
weather_key="xxx"

[mail]
pagesize=30
host="mysite.com"

[mail.db]
db_file='mail.db'
maxsize=10
minsize=2
idle_timeout=30

